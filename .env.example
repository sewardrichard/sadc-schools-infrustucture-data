# GigaMaps SADC School Data Extraction - Environment Variables
# Copy this file to .env and fill in your API keys.
#
# Get your API keys from the GigaMaps API portal:
#   https://uni-ooi-giga-maps-service.azurewebsites.net/api/v1/

# Bearer token for the School Location API
GIGA_SCHOOL_LOCATION_API_KEY=your_location_api_key_here

# Bearer token for the School Profile API
GIGA_SCHOOL_PROFILE_API_KEY=your_profile_api_key_here

# (Optional) Override the base API URL (defaults to production)
# GIGA_MAPS_BASE_URL=https://uni-ooi-giga-maps-service.azurewebsites.net/api/v1
